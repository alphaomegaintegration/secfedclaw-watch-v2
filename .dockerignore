# Keep the build context small and NEVER leak secrets or operator data into a
# layer. tests/ is intentionally NOT excluded — the CI build-and-test job runs
# the suite inside the built image to prove it actually works.

# secrets — never copy
.env
.env.*
!.env.example
.hermes_history

# operator data + custody (mount as volumes instead; huge + sensitive)
out/
flatfiles/
live_cache/
logs/
state/

# local dev
.venv/
venv/
.git/
.github/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# screenshots / scratch from this repo's tooling
.dr/
.shot/

# editor / OS
.DS_Store
.idea/
.vscode/
