# SECFEDCLAW .env template — copy to .env and fill in. NO real values here.
# Everything is OPTIONAL: with no keys, the system runs fully offline in replay
# mode. Add only the sources you want live. SEC EDGAR / StockTwits / FINRA /
# Nasdaq need no key. `.env` is gitignored; this template is not.

# ---- Market data ----------------------------------------------------------
POLYGON_API_KEY=
FMP_API_KEY=                       # Financial Modeling Prep (quotes/profiles), optional

# Polygon Flat Files (S3 history) for the backtest — stdlib SigV4, no boto3
MASSIVE_FLATFILES_ACCESS_KEY=
MASSIVE_FLATFILES_SECRET_KEY=
MASSIVE_FLATFILES_ENDPOINT=
MASSIVE_FLATFILES_BUCKET=

# ---- Official (SEC/FINRA/Nasdaq) ------------------------------------------
# EDGAR APIs are keyless; they only require a descriptive User-Agent.
SEC_USER_AGENT=your-name your-email@example.com

# ---- Social ---------------------------------------------------------------
X_BEARER_TOKEN=                    # or TWITTER_BEARER_TOKEN
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=                 # comma-separated server IDs
FIRECRAWL_API_KEY=                 # fallback web/social search + Instagram/Facebook

# ---- Search LLM (Scout web/social search, via scrapegraphai) --------------
# Default provider is Gemini. Pick ONE path:
GEMINI_API_KEY=                    # Google AI Studio — default search LLM
# SGAI_MODEL=ollama/llama3.1       # free local fallback (no key; install Ollama)
# SGAI_MODEL=openai/gpt-4o-mini    # + OPENROUTER_API_KEY
# SGAI_MODEL=bedrock/anthropic.claude-3-5-haiku-20241022-v1:0   # AWS Bedrock (no key; instance role)
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# AWS_REGION=us-east-1             # for Bedrock (credentials via the standard AWS chain)
# Tuning: SGAI_SEARCH_RESULTS / SGAI_MAX_SEARCHES / SGAI_MAX_TOKENS / SGAI_MAX_BROWSERS

# ---- Explanation LLM (5th agent; off by default) --------------------------
# SECFEDCLAW_LLM_EXPLAIN=1         # opt in to LLM review summaries (else template)
# SECFEDCLAW_LLM_MODEL=anthropic/claude-3.5-haiku  # or bedrock/<model-id>
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=              # (shared with search above)

# ---- Notifications & dashboard --------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=
# SECFEDCLAW_DASHBOARD_URL=http://127.0.0.1:8787/dashboard_v2.html

# ---- Opt-in gates (off by default) ----------------------------------------
# SECFEDCLAW_AUTHORIZED_SOCIAL=1   # enable lawful Discord/Telegram import
# SECFEDCLAW_SOCIAL_INTEL=1        # cross-platform coordinated-push intel
# SECFEDCLAW_SOCIAL_INTEL_LLM=1    # LLM urgency/FOMO node (needs SOCIAL_INTEL=1)
